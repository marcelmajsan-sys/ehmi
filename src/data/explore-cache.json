    "question": "Koje načine dostave biraju trgovci ovisno o prosječnom iznosu košarice?",
    "sql": "SELECT\n    r.q27_koji_vam_je_prosjecni_iznos_kosarice AS prosjecni_iznos_kosarice,\n    ro.option_value AS nacin_dostave,\n    COUNT(DISTINCT r.respondent_id) AS broj_trgovaca\nFROM responses r\nJOIN response_options ro\n    ON ro.respondent_id = r.respondent_id\n    AND ro.question_key = 'q10_koji_nacin_dostave_nudite'\nWHERE r.q27_koji_vam_je_prosjecni_iznos_kosarice IS NOT NULL\n  AND r.q27_koji_vam_je_prosjecni_iznos_kosarice <> 'Ne znam/nisam siguran'\n  AND ro.option_value NOT IN ('Nešto drugo')\nGROUP BY r.q27_koji_vam_je_prosjecni_iznos_kosarice, ro.option_value\nORDER BY\n    CASE r.q27_koji_vam_je_prosjecni_iznos_kosarice\n        WHEN 'Do 50 €'        THEN 1\n        WHEN '50 do 100 €'    THEN 2\n        WHEN '100 do 200€'    THEN 3\n        WHEN '200 do 500€'    THEN 4\n        WHEN '500 do 1000€'   THEN 5\n        WHEN 'Više od 1000€'  THEN 6\n    END,\n    broj_trgovaca DESC\nLIMIT 500",
