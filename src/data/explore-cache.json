  {
    "question": "Koliko trgovaca koristi WooCommerce?",
    "sql": "SELECT COUNT(DISTINCT respondent_id) AS broj_trgovaca\nFROM response_options\nWHERE question_key = 'q04_na_kojoj_platformi_se_nalazi_vas_webshop'\n  AND option_value ILIKE '%woocommerce%'\nLIMIT 50",
